generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum Role {
  ADMIN
  USER
}

enum MediaType {
  IMAGE
  YOUTUBE
}

enum Status {
  ACTIVE
  INACTIVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

// -----------------------------------------------------------------------------
// Models
// -----------------------------------------------------------------------------

model User {
  id        String   @id @default(uuid())
  userId    String   @unique
  fullName  String
  username  String   @unique
  email     String?  @unique
  password  String
  role      Role     @default(USER)
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  attendances   Attendance[]
  journals      JournalEntry[]
  registrations EventRegistration[]

  @@index([username])
  @@index([userId])
}

model Attendance {
  id        String           @id @default(uuid())
  userId    String
  sabhaDate DateTime         @db.Date
  sabhaName String
  startTime DateTime         @db.Time
  endTime   DateTime         @db.Time
  status    AttendanceStatus
  createdAt DateTime         @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sabhaDate, sabhaName]) // Optional: Prevent double attendance for same sabha
  @@index([userId])
  @@index([sabhaDate])
}

model JournalEntry {
  id        String   @id @default(uuid())
  userId    String
  sabhaDate DateTime @db.Date
  title     String
  learning  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sabhaDate])
}

model Notice {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  priority    Priority @default(MEDIUM)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([priority])
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  venue       String
  eventDate   DateTime @db.Date
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  registrations EventRegistration[]

  @@index([eventDate])
}

model EventRegistration {
  id           String   @id @default(uuid())
  userId       String
  eventId      String
  registeredAt DateTime @default(now())

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Constraint: One user can only register once per event
  @@unique([userId, eventId])
  @@index([eventId])
  @@index([userId])
}

model Gallery {
  id          String   @id @default(uuid())
  eventName   String
  title       String?
  description String?
  imageUrl    String
  publicId    String
  uploadedAt  DateTime @default(now())

  @@index([eventName])
}

model HeroBanner {
  id            String    @id @default(uuid())
  title         String?
  subtitle      String?
  imageUrl      String?
  imagePublicId String?
  buttonText    String?
  buttonLink    String?
  startDate     DateTime?
  endDate       DateTime?
  displayOrder  Int       @unique
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  mediaType      MediaType @default(IMAGE)
  youtubeUrl     String?
  youtubeVideoId String?
  thumbnailUrl   String?

  @@index([displayOrder])
}
